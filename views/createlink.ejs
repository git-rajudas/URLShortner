<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Short Link</title>
    <link rel="stylesheet" href="/output.css" />
    <link rel="shortcut icon" href="/images/favicon.svg" type="image/x-icon">
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.9.0/fonts/remixicon.css" rel="stylesheet" />
</head>
<body>
    <%- include('partials/nav') %>
    <div class="w-full flex flex-col flex-grow items-center justify-center text-center gap-5 mt-5 sm:mt-10 px-10 py-10 sm:px-20">
        <h1 class="w-full text-3xl font-[EB-Garamond] font-bold text-start">Create New Link</h1>
        <div class="flex flex-col flex-grow sm:flex-row w-full sm:gap-10 gap-5 items-center justify-between">
            <div class="flex flex-col items-start justify-between gap-5 w-full  sm:w-full py-10 sm:bg-white sm:border sm:border-[#666666] sm:rounded sm:px-10 sm:py-10">
                <h1 class="text-xl text-start">Enter Link Details</h1>
                 
                <form id="createForm" action="/createlink" method="post" class="w-full flex flex-col items-start justify-between gap-5 mt-2">
                    <div class="  w-full flex flex-col item-start justify-between gap-2 ">
                        <label class="text-xl text-start" for="title">Title:</label>
                        <input class="w-full px-4 py-3 outline-none border border-black" type="text" id="title" name="title">
                    </div>
                    <div class="  w-full flex flex-col item-start justify-between gap-2 ">
                        <label class="text-xl text-start" for="url">Redirect URL / Original Url:</label>
                        <input class="w-full px-4 py-3 outline-none border border-black" type="url" id="url" name="url" required>
                    </div>
                </form>
            </div>


            <div class="flex flex-col items-start justify-between gap-5 w-full  sm:w-1/2 py-10  sm:px-10 sm:py-10 ">
    
                 <h1 class="text-xl text-start">Generate QR Code</h1>
                 <div class="w-full border border-black rounded flex flex-col items-center justify-center  gap-5 sm:bg-white" >
                    <div class="w-[50%] flex flex-col justify-between py-10 sm:py-10 items-center gap-3">
                        <img class="w-[60%] " id="qrImage" src="images/qr-code.png" alt="QR Code" >
                        <h3 class="text-sm text-center">Enter the long url to generate a QR code.</h3>
                    </div>
                 </div>
            </div>
        </div>

        <div class="border border-black w-full"></div>

        <div class="w-full flex flex-row justify-end items-center gap-5">
            <button type="reset" class="w-full px-4 py-3 bg-white border border-black text-black cursor-pointer sm:w-auto">Reset To Defaults</button>
            <button type="submit" form="createForm" class="w-full px-4 py-3 bg-black text-white cursor-pointer sm:w-auto">Create New Link</button>
            
        </div>

    </div>
    <%- include('partials/footer') %>




    <script>
        const input = document.getElementById("url");
        const qrImage = document.querySelector("#qrImage");

        input.addEventListener("input",()=>{
            const url = input.value;
            if(url){
                qrImage.src = `https://api.qrserver.com/v1/create-qr-code/?data=${url}&size=500x500`
            }else{
                qrImage.src = "images/qr-code.png";
            }
        })
    </script>



</body>
</html>