<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Link Shotner</title>
    <link rel="stylesheet" href="/output.css">
    <link rel="stylesheet" href="/style.css">
    <!-- <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script> -->
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.9.0/fonts/remixicon.css" rel="stylesheet" />
    <link rel="shortcut icon" href="/images/favicon.svg" type="image/x-icon">

</head>

<body class="min-h-screen flex flex-col">
    <%- include('partials/nav') %>
        <div id="hero" class="w-full flex flex-col flex-grow items-center justify-center text-center gap-4 mt-20 mb-20 px-10 ">
            <div class="w-full flex flex-col items-center justify-center text-center gap-4">
                <h2 class="text-xl uppercase tracking-wider font-extralight sm:text-2xl sm:font-light">Simplify Your
                    Links</h2>
                <h1 class="text-3xl font-[EB-Garamond] sm:text-6xl sm:font-bold">Transform Long Urls,<br> into
                    Tiny Links Instantly!</h1>
                <p class="text-base px-5 sm:text-lg">Your go to solution for smarter sharing. Paste your long link
                    below.</p>
            </div>
            <div class="w-full sm:w-1/2 flex flex-col items-center justify-center gap-4">
                <form action="\createlink" method="post"
                    class="w-full flex flex-col sm:flex-row items-center justify-between mt-2 border border-black text-center">
                    <input type="text" name="url" placeholder="https://example.com/long-url"
                        class="w-full px-4 py-3 outline-none border border-black">
                    <input type="submit" value="Generate Link - Its Free"
                        class="w-full px-4 py-3 bg-[#27272A] text-white border border-black sm:w-auto sm:mt-0 cursor-pointer">
                </form>
                <div class="flex items-center justify-center gap-2">
                    <p class="text-base text-black mt-5">1k+ people already using it.</p>
                    <img class="w-5 h-auto mt-5" src="undraw_fun-arrow.svg" alt="">
                </div>
            </div>
        </div>
        <%- include('partials/footer') %>

</body>

</html>