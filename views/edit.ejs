<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Link</title>
    <link rel="stylesheet" href="/output.css">
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.9.0/fonts/remixicon.css" rel="stylesheet" />
    <link rel="shortcut icon" href="/images/favicon.svg" type="image/x-icon">
</head>

<body class="min-h-screen flex flex-col">
    <%-include('partials/nav') %>

        <div
            class="w-full flex flex-col flex-grow items-center justify-center text-center gap-5 mt-5 sm:mt-10 px-10 py-10 sm:px-20">

            <h1 class="w-full text-3xl font-[EB-Garamond] font-bold text-start">Edit Link Details Or Delete It</h1>
            <div class="flex flex-col flex-grow w-full sm:gap-10 gap-5 items-center justify-between">
                <div
                    class="flex flex-col items-start justify-between gap-5 w-full  sm:w-full py-10 sm:bg-white sm:border sm:border-[#666666] sm:rounded sm:px-10 sm:py-10">
                    <h1 class="text-xl text-start">Enter Link Details</h1>

                    <form id="editLink" action="/save/<%= url.shortId %>" method="post"
                        class="w-full flex flex-col items-start justify-between gap-5 mt-2">
                        <div class="  w-full flex flex-col item-start justify-between gap-2 ">
                            <label class="text-xl text-start" for="title">Title:</label>
                            <input class="w-full px-4 py-3 outline-none border border-black" type="text" id="title"
                                name="title" value= "<%= url.title %>">
                        </div>
                        <div class="  w-full flex flex-col item-start justify-between gap-2 ">
                            <label class="text-xl text-start" for="url">Redirect URL / Original Url:</label>
                            <div
                                class="w-full px-4 py-3 outline-none border border-black flex flex-row items-start justify-between gap-1">
                                <a class="text-base text-[#A1A1B2] italic"><%= url.redirectUrl.length> 40 ? url.redirectUrl.slice(0, 40) + "..." : url.redirectUrl
                                    %></a>
                            </div>
                        </div>
                    </form>

                    <p class="text-base text-center italic ">Deleting this link will remove all of its details. This
                        action cannot be undone.</p>

                </div>

                <div class="border border-black w-full"></div>

                <div class="w-full flex flex-row justify-end items-center gap-5">
                    <button type="submit" form="editLink"
                        class="w-full px-4 py-3 bg-white border border-black text-black cursor-pointer sm:w-auto rounded">Save
                        Details</button>

                    <a href="/delete/<%= url.shortId %>" class="w-full px-4 py-3 bg-[#EF4444] text-white cursor-pointer sm:w-auto rounded">Delete Link</a>
                </div>

            </div>
        </div>
        
        <%- include('partials/footer') %>
</body>

</html>