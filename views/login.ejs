<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login Your Account</title>
    <link rel="stylesheet" href="/output.css">
    <!-- <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script> -->
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.9.0/fonts/remixicon.css" rel="stylesheet" />
</head>
<body>
    <%- include('partials/nav') %>
    <main id="login-main" class="w-full flex-grow flex flex-col items-center justify-between mt-10 px-10 gap:5 sm:flex-row ">
        <div id="login-form" class="flex flex-col items-start justify-between gap-5 w-full sm:px-20 sm:w-1/2 ">
            <h1 class="text-3xl font-[EB-Garamond] font-semibold">Login Your Account</h1>
            <form action="/login" method="post" class=" w-full flex flex-col item-start justify-between gap-5 mt-2">
                <div class="  w-full flex flex-col item-start justify-between gap-2 ">
                    <label for="email" class="text-xl">Your email</label>
                    <input class="w-full px-4 py-3 outline-none border border-black" type="email" name="email" id="email" placeholder="jonedeo@mail.com">
                </div>
                <div class=" w-full flex flex-col item-start justify-between gap-2">
                    <label for="password" class="text-xl">Password</label>
                    <input class="w-full px-4 py-3 outline-none border border-black" type="password" name="password" id="password" placeholder="8+ Characters">
                </div>
                <button type="submit" class="w-full px-4 py-3 bg-black text-white cursor">Login to Dashboard</button>
            </form>
        <p id="login-privacy-text" class="text-base">By continuing, I agree to the Terms of Use & Privacy Policy</p>
        <p id="createAccout" class="text-base">Don't have an Account? <a class="font-semibold cursor" href="/signup">Create Account</a></p>
        </div>
        <div id="login-img" class="w-full mt-10 sm:flex-1">
            <img class="w-[80%] h-auto" src="/images/greetings-Ba8Y3FiR.png" alt="">
        </div>
    </main>
    <%- include('partials/footer') %>
</body>
</html>