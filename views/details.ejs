<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Link Details</title>
    <link rel="stylesheet" href="/output.css" />
    <link rel="shortcut icon" href="/images/favicon.svg" type="image/x-icon">
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.9.0/fonts/remixicon.css" rel="stylesheet" />
</head>

<body class="min-h-screen flex flex-col">
    <%- include('partials/nav') %>

        <div
            class="w-full flex flex-col flex-grow items-center justify-center text-center gap-4 mt-10 sm:mt-20 mb-20 px-10 sm:px-20">
            <div class="w-full max-w-3xl sm:max-w-[100%] flex flex-col items-start justify-start gap-6">
                <div
                    class="w-full flex flex-col sm:flex-row items-start justify-between p-4  sm:p-10 gap-4 bg-white border border-zinc-400">
                    <div class="w-full flex flex-col items-start justify-between p-4 gap-4">
                        <!-- Image, Title and URL -->
                        <div class="flex flex-col gap-4 items-start justify-between w-full">
                            <div
                                class="w-[50px] sm:w-[90px] h-auto rounded-full bg-zinc-200 p-1 border border-zinc-200 overflow-hidden mt-1">
                                <img src="https://www.google.com/s2/favicons?domain=<%= url.redirectUrl %>&sz=64" alt=""
                                    class="blur-0 rounded-full w-full h-full">
                            </div>
                            <div class="flex flex-col items-start justify-start gap-2 w-full">
                                <h1 class="text-2xl text-start ">
                                    <%= url.title %>
                                </h1>
                                <div
                                    class="text-base font-semibold flex flex-row items-center justify-between gap-2 text-blue-500 ">
                                    <i class="ri-link"></i><a id="QrUrl" href="/<%= url.shortId %>" target="_blank">
                                        <%= protocol + '://' + host + "/" + url.shortId %>
                                    </a>
                                    <i onclick="copyLink('<%= protocol %>://<%= host %>/<%= url.shortId %>')" class="ri-file-copy-line"></i>
                                </div>
                            </div>
                        </div>

                        <!-- Destination URL  -->
                        <div class="flex flex-col items-start justify-between gap-1">
                            <h2 class="text-xl">Destination URL:</h2>
                            <a href="<%= url.redirectUrl %>" target="_blank" class="text-base text-[#A1A1B2] italic">
                                <%= url.redirectUrl.length> 35 ? url.redirectUrl.slice(0, 35) + "..." : url.redirectUrl
                                    %>
                            </a>
                        </div>

                        <!-- Created At, Updated At -->
                        <div class="flex flex-col items-start justify-between gap-1">
                            <div class="flex flex-row items-start justify-between gap-2">
                                <h2 class="text-base">Created At:</h2>
                                <div class="text-sm text-[#A1A1B2]">
                                    <%= new Date(url.createdAt).toLocaleString('en-IN', {dateStyle: 'medium'
                                        ,timeStyle: 'medium' }) %>
                                </div>
                            </div>
                            <div class="flex flex-row items-start justify-between gap-2">
                                <h2 class="text-base">Updated At:</h2>
                                <div class="text-sm text-[#A1A1B2]">
                                    <%= new Date(url.updatedAt).toLocaleString('en-IN', {dateStyle: 'medium'
                                        ,timeStyle: 'medium' }) %>
                                </div>
                            </div>
                        </div>

                    </div>

                    <div class="hidden sm:flex sm:flex-grow sm:w-[30%] m-10">
                        <div class="w-full h-full flex flex-col items-center justify-center">
                            <img id="qrImage" src="" alt="" class="w-full h-auto">
                            <div>
                                <button
                                    class="w-full bg-black px-4 py-3 text-white rounded mt-5 sm:w-auto cursor-pointer"
                                    onclick="copyLink('<%= protocol %>://<%= host %>/<%= url.shortId %>')">
                                    <i class="ri-file-copy-line"></i> Copy Qr Code Link
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Buttons -->
                <div 
                    class="w-full sm:flex sm:flex-row sm:items-center sm:justify-between  sm:p-10 sm:bg-white sm:border sm:border-zinc-400">
                    <div class="hidden sm:flex text-2xl">Actions</div>
                    <div class="flex flex-col sm:w-[40%] sm:flex-row items-center justify-between gap-2">
                        <a href=""
                            class="w-full text-base flex flex-row items-center justify-center p-4  sm:py-4 sm:px-8 gap-4 bg-white border border-zinc-400"><i
                                class="ri-share-line"></i> Share</a>
                        <a href=""
                            class="w-full text-base flex flex-row items-center justify-center p-4  sm:py-4 sm:px-8 gap-4 bg-black text-white border border-zinc-400"><i
                                class="ri-edit-line"></i> Edit / Delete</a>
                    </div>
                </div>
            </div>
        </div>

        <%- include('partials/footer') %>



            <script>
                const qrImage = document.querySelector("#qrImage");
                const QrUrl = document.getElementById("QrUrl").href;


                window.addEventListener("load", () => {
                    if (QrUrl) {
                        qrImage.src = `https://api.qrserver.com/v1/create-qr-code/?data=${QrUrl}&size=500x500`
                    } else {
                        qrImage.src = "images/qr-code.png";
                    }
                })

                function copyLink(link) {
                    navigator.clipboard.writeText(link);
                }



            </script>
</body>

</html>